# vim: ft=sh

[[ $PATH == *"$HOME/bin"* ]] || export PATH=$HOME/bin:$PATH:

for file in ~/.config/shell/{paths,exports,functions,extra}; do
  [ -r "$file" ] && [ -f "$file" ] && source "$file";
done;
unset file

if [ $SHELL = "/bin/zsh" ]; then
  [ -r "$file" ] && [ -f "$file" ] && source ~/.config/shell/aliases;
fi

